---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found | icrabuilders.com" noindex={true}>
  <main class="flex min-h-screen items-center justify-center bg-slate-900">
    <div class="text-center px-6">
      <div class="text-teal-400 text-8xl font-bold mb-4">404</div>
      <h1 class="text-white text-2xl md:text-3xl font-semibold mb-4">Page Not Found</h1>
      <p class="text-slate-400 max-w-md mx-auto mb-8">
        The page you're looking for doesn't exist. icrabuilders.com is a premium domain available for acquisition.
      </p>
      <a href="/" class="inline-flex items-center gap-2 px-8 py-3 bg-teal-600 hover:bg-teal-700 text-white font-semibold rounded-3xl transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955a1.126 1.126 0 011.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>
        <span>Return Home</span>
      </a>
    </div>
  </main>
</BaseLayout>
