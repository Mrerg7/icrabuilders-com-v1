---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import InquiryModal from '../components/InquiryModal.astro';
import { SITE_NAME, ACQUISITION_EMAIL } from '../lib/constants';
---

<BaseLayout>
  <Nav />

  <!-- Hero Section -->
  <header class="healthcare-gradient text-white">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-8 pt-12 pb-16 md:pt-20 md:pb-24">
      <div class="max-w-4xl">
        <div class="inline-flex items-center gap-x-2 bg-white/10 backdrop-blur-md px-4 py-1.5 rounded-3xl mb-6 border border-white/20">
          <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></div>
          <span class="text-sm font-medium tracking-wide">EXCLUSIVELY AVAILABLE</span>
        </div>

        <h1 class="text-5xl sm:text-6xl md:text-7xl leading-[1.05] tracking-tighter font-semibold mb-4">
          icrabuilders.com
        </h1>

        <p class="max-w-3xl text-xl sm:text-2xl md:text-3xl text-teal-100 tracking-tight mb-3">
          The premium .com brand for ICRA Builders.
        </p>

        <p class="max-w-2xl text-base sm:text-lg text-teal-200/90 mb-9">
          Own the clean, authoritative, and highly brandable name that represents specialized expertise
          in Infection Control Risk Assessment for healthcare construction and renovation.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <button onclick="showInquiryModal()"
                  class="group inline-flex items-center justify-center gap-x-3 px-8 py-4 bg-white text-teal-700 font-semibold text-base sm:text-lg rounded-3xl hover:bg-teal-50 active:bg-white transition-all shadow-xl shadow-black/10">
            <span>Secure This Domain</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-active:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
            </svg>
          </button>

          <a href="#opportunity"
             class="inline-flex items-center justify-center gap-x-2 px-7 py-4 border border-white/30 hover:bg-white/10 text-white font-medium rounded-3xl transition-all text-base sm:text-lg">
            <span>Explore the Opportunity</span>
          </a>
        </div>

        <div class="mt-8 flex items-center gap-x-6 text-sm">
          <div class="flex items-center -space-x-1" aria-hidden="true">
            <div class="w-6 h-6 bg-white/20 rounded-full border border-white/40"></div>
            <div class="w-6 h-6 bg-white/20 rounded-full border border-white/40"></div>
            <div class="w-6 h-6 bg-white/20 rounded-full border border-white/40"></div>
          </div>
          <span class="text-teal-200 text-sm">The established .com name in healthcare construction compliance</span>
        </div>
      </div>
    </div>
  </header>

  <!-- Trust / Stats Bar -->
  <div class="border-b border-slate-200 bg-white">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-8 py-5">
      <div class="flex flex-wrap justify-center md:justify-between items-center gap-x-8 gap-y-4 text-center md:text-left">
        <div class="flex items-center gap-x-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span class="font-medium text-sm text-slate-600">Premium exact-phrase .com domain</span>
        </div>
        <div class="flex items-center gap-x-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span class="font-medium text-sm text-slate-600">Healthcare construction &amp; renovation market expanding rapidly</span>
        </div>
        <div class="flex items-center gap-x-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span class="font-medium text-sm text-slate-600">ICRA capability is a major competitive advantage</span>
        </div>
      </div>
    </div>
  </div>

  <!-- The Opportunity Section -->
  <section id="opportunity" class="max-w-screen-2xl mx-auto px-6 md:px-8 pt-16 pb-12">
    <div class="max-w-3xl mb-10">
      <div class="uppercase tracking-[2px] text-teal-600 text-xs font-semibold mb-2">THE MARKET OPPORTUNITY</div>
      <h2 class="section-header tracking-tighter">ICRA expertise is becoming a core requirement in healthcare construction.</h2>
      <p class="mt-4 text-lg text-slate-600">Hospitals and health systems are spending tens of billions annually on new construction, expansions, and renovations — much of it in occupied facilities. Projects that ignore proper Infection Control Risk Assessment face delays, failed inspections, patient safety risks, and damaged reputations. The contractors and organizations that master ICRA win more work and build lasting trust.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-5">
      <div class="bg-white border border-slate-200 rounded-3xl p-7 modern-card">
        <div class="flex justify-between items-start">
          <div>
            <div class="text-5xl font-semibold tracking-tighter text-slate-900">$30B+</div>
            <div class="text-teal-600 font-medium mt-1">Annual U.S. hospital &amp; clinic construction spend</div>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-teal-100" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21v12H3V7.5z"/></svg>
        </div>
        <p class="text-sm text-slate-500 mt-5 leading-snug">Spending continues to grow through 2030 as health systems modernize aging infrastructure and expand capacity in high-growth markets.</p>
      </div>

      <div class="bg-white border border-slate-200 rounded-3xl p-7 modern-card">
        <div class="flex justify-between items-start">
          <div>
            <div class="text-5xl font-semibold tracking-tighter text-slate-900">High Stakes</div>
            <div class="text-teal-600 font-medium mt-1">ICRA failures carry serious consequences</div>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-amber-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>
        </div>
        <p class="text-sm text-slate-500 mt-5 leading-snug">Dust breaches, pressure failures, and contamination events can lead to Joint Commission citations, CMS issues, project shutdowns, and real harm to vulnerable patients.</p>
      </div>

      <div class="bg-white border border-slate-200 rounded-3xl p-7 modern-card">
        <div class="flex justify-between items-start">
          <div>
            <div class="text-5xl font-semibold tracking-tighter text-slate-900">Clear Winner</div>
            <div class="text-teal-600 font-medium mt-1">Specialized expertise wins bids</div>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-teal-100" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M18.75 4.236c.982.143 1.954.317 2.916.52A6.003 6.003 0 0016.27 9.728M18.75 4.236V4.5c0 2.108-.966 3.99-2.48 5.228m0 0a6.023 6.023 0 01-2.77.774 6.023 6.023 0 01-2.77-.774"/></svg>
        </div>
        <p class="text-sm text-slate-500 mt-5 leading-snug">Health systems and general contractors increasingly seek partners who truly understand and execute ICRA protocols — not just check boxes on a form.</p>
      </div>
    </div>
  </section>

  <!-- The Brand Section -->
  <section id="brand" class="bg-white border-y border-slate-200 py-16">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-8">
      <div class="max-w-3xl mb-10">
        <div class="uppercase tracking-[2px] text-teal-600 text-xs font-semibold mb-2">THE ICRA BUILDERS BRAND</div>
        <h2 class="section-header tracking-tighter">What icrabuilders.com represents.</h2>
        <p class="mt-4 text-lg text-slate-600">This is more than a domain. It's a complete brand identity that instantly communicates professionalism, specialization, and authority in the critical intersection of healthcare construction and infection control.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
        <div class="bg-slate-50 border border-slate-100 rounded-3xl p-6 modern-card">
          <div class="w-11 h-11 flex items-center justify-center bg-teal-100 text-teal-600 rounded-2xl mb-5" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
          </div>
          <h4 class="font-semibold text-lg tracking-tight mb-2">Patient Protection First</h4>
          <p class="text-sm text-slate-600 leading-relaxed">The brand stands for rigorous adherence to ICRA protocols — proper containment, pressure management, monitoring, and collaboration with infection prevention teams on every project.</p>
        </div>

        <div class="bg-slate-50 border border-slate-100 rounded-3xl p-6 modern-card">
          <div class="w-11 h-11 flex items-center justify-center bg-teal-100 text-teal-600 rounded-2xl mb-5" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 5.25h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5"/></svg>
          </div>
          <h4 class="font-semibold text-lg tracking-tight mb-2">Construction Excellence</h4>
          <p class="text-sm text-slate-600 leading-relaxed">Real-world experience delivering complex healthcare projects — renovations in occupied facilities, ORs, isolation rooms, and sensitive clinical environments without compromising safety or schedules.</p>
        </div>

        <div class="bg-slate-50 border border-slate-100 rounded-3xl p-6 modern-card">
          <div class="w-11 h-11 flex items-center justify-center bg-teal-100 text-teal-600 rounded-2xl mb-5" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"/></svg>
          </div>
          <h4 class="font-semibold text-lg tracking-tight mb-2">Training &amp; Standards</h4>
          <p class="text-sm text-slate-600 leading-relaxed">Commitment to developing and maintaining a highly trained workforce that understands both the "why" and the "how" of infection control during construction.</p>
        </div>

        <div class="bg-slate-50 border border-slate-100 rounded-3xl p-6 modern-card">
          <div class="w-11 h-11 flex items-center justify-center bg-teal-100 text-teal-600 rounded-2xl mb-5" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
          </div>
          <h4 class="font-semibold text-lg tracking-tight mb-2">Trusted Partnership</h4>
          <p class="text-sm text-slate-600 leading-relaxed">The name signals reliability to hospital administrators, facility directors, architects, and general contractors who need a specialist they can count on for high-stakes work.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why This Domain Section -->
  <section id="why-domain" class="max-w-screen-2xl mx-auto px-6 md:px-8 py-16">
    <div class="max-w-3xl mb-9">
      <div class="uppercase tracking-[2px] text-teal-600 text-xs font-semibold mb-2">THE STRATEGIC ASSET</div>
      <h2 class="section-header tracking-tighter">Why icrabuilders.com is a powerful premium brand.</h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      <div class="bg-white border border-slate-200 p-7 rounded-3xl modern-card">
        <div class="flex items-center gap-x-3 mb-4">
          <div class="text-teal-600" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h4 class="font-semibold text-xl tracking-tight">Full Phrase .com Ownership</h4>
        </div>
        <p class="text-slate-600">You own the complete, natural-language name "ICRA Builders" as a .com. This is the cleanest, most professional expression of the brand — ideal for contracts, proposals, websites, and long-term equity.</p>
      </div>

      <div class="bg-white border border-slate-200 p-7 rounded-3xl modern-card">
        <div class="flex items-center gap-x-3 mb-4">
          <div class="text-teal-600" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
          </div>
          <h4 class="font-semibold text-xl tracking-tight">Professional Email &amp; Communications</h4>
        </div>
        <p class="text-slate-600">@icrabuilders.com addresses look established and trustworthy. Perfect for project managers, estimators, executives, and client communications in a relationship-driven industry.</p>
      </div>

      <div class="bg-white border border-slate-200 p-7 rounded-3xl modern-card">
        <div class="flex items-center gap-x-3 mb-4">
          <div class="text-teal-600" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/></svg>
          </div>
          <h4 class="font-semibold text-xl tracking-tight">Highly Brandable &amp; Memorable</h4>
        </div>
        <p class="text-slate-600">Clean, readable, and easy to say and spell. Performs exceptionally well on business cards, vehicle graphics, job site signage, marketing materials, and verbal introductions.</p>
      </div>

      <div class="bg-white border border-slate-200 p-7 rounded-3xl modern-card">
        <div class="flex items-center gap-x-3 mb-4">
          <div class="text-teal-600" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>
          </div>
          <h4 class="font-semibold text-xl tracking-tight">Strong Search &amp; SEO Potential</h4>
        </div>
        <p class="text-slate-600">Direct alignment with high-intent searches for "ICRA builders", "ICRA construction", "healthcare construction ICRA", and related terms in a growing niche.</p>
      </div>

      <div class="bg-white border border-slate-200 p-7 rounded-3xl modern-card">
        <div class="flex items-center gap-x-3 mb-4">
          <div class="text-teal-600" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M2.985 19.644v-4.992"/></svg>
          </div>
          <h4 class="font-semibold text-xl tracking-tight">Future-Proof &amp; Evergreen</h4>
        </div>
        <p class="text-slate-600">Healthcare facilities will always need renovation and expansion work. ICRA requirements continue to evolve and tighten. This brand has lasting relevance and value.</p>
      </div>

      <div class="bg-white border border-slate-200 p-7 rounded-3xl modern-card">
        <div class="flex items-center gap-x-3 mb-4">
          <div class="text-teal-600" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"/></svg>
          </div>
          <h4 class="font-semibold text-xl tracking-tight">Multiple High-Value Paths</h4>
        </div>
        <p class="text-slate-600">Launch a specialized construction or renovation firm • Build a training &amp; certification business • Create compliance software or platforms • Establish a consulting practice • Develop a national network under one strong brand.</p>
      </div>
    </div>
  </section>

  <!-- Business Models / Use Cases -->
  <section class="bg-slate-900 text-white py-16">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-8">
      <div class="max-w-2xl mb-9">
        <div class="text-teal-400 text-xs tracking-[2px] font-semibold mb-2">ACTIVATE THE BRAND</div>
        <h2 class="text-4xl tracking-tighter font-semibold">Proven ways to build real value with icrabuilders.com.</h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-white/5 hover:bg-white/10 border border-white/10 p-6 rounded-3xl transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-teal-400 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 5.25h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5m-16.5 4.5h16.5"/></svg>
          <h5 class="font-semibold mb-1.5">Specialized Healthcare Construction Firm</h5>
          <p class="text-sm text-white/70">Operate as a premier contractor focused on ICRA-compliant work in occupied hospitals, clinics, and medical facilities.</p>
        </div>
        <div class="bg-white/5 hover:bg-white/10 border border-white/10 p-6 rounded-3xl transition-colors">
